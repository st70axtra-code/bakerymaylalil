// รองรับการใช้งานออนไลน์ทั่วไปผ่าน localStorage หากไม่มี window.storage ของแอปเฉพาะ
async function loadKey(key, fallback) {
  try {
    if (window.storage) {
      const res = await window.storage.get(key, false);
      return res ? JSON.parse(res.value) : fallback;
    }
    const localRes = localStorage.getItem(key);
    return localRes ? JSON.parse(localRes) : fallback;
  } catch (e) {
    return fallback;
  }
}

async function saveKey(key, value) {
  try {
    if (window.storage) {
      await window.storage.set(key, JSON.stringify(value), false);
      return;
    }
    localStorage.setItem(key, JSON.stringify(value));
  } catch (e) {
    console.error("save failed", key, e);
  }
}

// ---------- PromptPay QR payload ----------
function crc16(str) {
  let crc = 0xffff;
  for (let i = 0; i < str.length; i++) {
    crc ^= str.charCodeAt(i) << 8;
    for (let j = 0; j < 8; j++) {
      crc = (crc & 0x8000) !== 0 ? ((crc << 1) ^ 0x1021) & 0xffff : (crc << 1) & 0xffff;
    }
  }
  return crc.toString(16).toUpperCase().padStart(4, "0");
}
const tlv = (id, value) => `${id}${String(value.length).padStart(2, "0")}${value}`;

function generatePromptPayPayload(target, amount) {
  const digits = String(target || "").replace(/\D/g, "");
  if (!digits) return null;
  let targetField;
  if (digits.length === 13) {
    targetField = tlv("02", digits);
  } else {
    let phone = digits.startsWith("0") ? digits.slice(1) : digits;
    phone = ("66" + phone).padStart(13, "0");
    targetField = tlv("01", phone);
  }
  const merchantInfo = tlv("00", "A000000677010111") + targetField;

  let payload = "";
  payload += tlv("00", "01");
  payload += tlv("01", amount ? "12" : "11");
  payload += tlv("29", merchantInfo);
  payload += tlv("58", "TH");
  payload += tlv("53", "764");
  if (amount) payload += tlv("54", Number(amount).toFixed(2));
  payload += "6304";
  payload += crc16(payload);
  return payload;
}

// ---------- Cost calculation with Unit Conversion ----------
function costOf(product, materials) {
  const materialsCost = (product.recipe || []).reduce((sum, r) => {
    const mat = materials.find((m) => m.id === r.materialId);
    if (!mat) return sum;

    // หาต้นทุนต่อหน่วยย่อยที่สุด (Base Unit Cost)
    const matUnitConfig = UNITS[mat.unit] || UNITS.g;
    const recipeUnitConfig = UNITS[r.unit] || UNITS.g;

    if (matUnitConfig.base !== recipeUnitConfig.base) {
      // ข้ามกรณีหน่วยไม่ตรงกันคนละประเภท เช่น ซื้อเป็นลิตร แต่ใช้เป็นกรัม
      return sum;
    }

    const totalBaseQtyBought = (Number(mat.packSize) || 1) * matUnitConfig.rate;
    const costPerBaseUnit = (Number(mat.pricePerUnit) || 0) / totalBaseBought;
    
    // แปลงปริมาณที่ใช้ในสูตรให้เป็นหน่วยย่อยที่สุด
    const recipeBaseQty = (Number(r.qty) || 0) * recipeUnitConfig.rate;

    return sum + (costPerBaseUnit * recipeBaseQty);
  }, 0);

  const laborCost = Number(product.laborCost) || 0;
  const otherCost = Number(product.otherCost) || 0;
  const batchCost = materialsCost + laborCost + otherCost;
  const yieldCount = Math.max(1, Number(product.batchYield) || 1);
  const costPerPiece = batchCost / yieldCount;

  return { materialsCost, laborCost, otherCost, batchCost, yieldCount, costPerPiece };
}

