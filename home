  }, []);

  // บันทึกข้อมูลอัตโนมัติเมื่อเกิดการเปลี่ยนแปลง
  useEffect(() => { if (materials.length > 0) saveKey("bakery_materials", materials); }, [materials]);
  useEffect(() => { if (products.length > 0) saveKey("bakery_products", products); }, [products]);
  useEffect(() => { saveKey("bakery_pp_id", promptPayId); }, [promptPayId]);

  const handleAddMaterial = () => {
    const newMat = { id: uid(), name: "วัตถุดิบใหม่", packSize: 1, unit: "kg", pricePerUnit: 0 };
