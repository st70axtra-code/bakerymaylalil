  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans pb-10">
      {/* Header */}
      <header className="bg-white border-b border-slate-200 sticky top-0 z-40 px-4 py-3 shadow-xs">
        <div className="max-w-5xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
          <div className="flex items-center gap-3">
            <div className="p-2.5 bg-rose-500 rounded-xl text-white shadow-md shadow-rose-100">
              <Cookie className="w-6 height-6" />
            </div>
            <div>
              <h1 className="text-xl font-bold tracking-tight">ระบบคำนวณต้นทุนเบเกอรี่ออนไลน์</h1>
              <p className="text-xs text-slate-500">จัดการสูตร, แปลงหน่วย และสร้าง QR รับเงิน</p>
            </div>
          </div>

          <div className="flex bg-slate-100 p-1 rounded-xl w-full sm:w-auto">
            <button 
              onClick={() => setActiveTab("products")}
              className={`flex-1 sm:flex-none px-4 py-2 rounded-lg text-sm font-medium transition-all flex items-center justify-center gap-2 ${activeTab === "products" ? "bg-white shadow-xs text-rose-600" : "text-slate-600 hover:text-slate-900"}`}
            >
              <PieChart className="w-4 h-4" /> เมนูเบเกอรี่
            </button>
            <button 
              onClick={() => setActiveTab("materials")}
              className={`flex-1 sm:flex-none px-4 py-2 rounded-lg text-sm font-medium transition-all flex items-center justify-center gap-2 ${activeTab === "materials" ? "bg-white shadow-xs text-rose-600" : "text-slate-600 hover:text-slate-900"}`}
            >
              <Package className="w-4 h-4" /> คลังวัตถุดิบ
            </button>
          </div>
        </div>
      </header>

      {/* Main Content Dashboard */}
      <main className="max-w-5xl mx-auto px-4 mt-6">
        {activeTab === "materials" && (
          <div className="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
            <div className="flex justify-between items-center mb-6">
              <div>
                <h2 className="text-lg font-bold">คลังวัตถุดิบทั้งหมด</h2>
                <p className="text-sm text-slate-500">ใส่ราคายกแพ็ค/ถุง ระบบจะคำนวณสัดส่วนตอนทำสูตรให้เอง</p>
              </div>
              <button onClick={handleAddMaterial} className="bg-rose-500 text-white px-4 py-2 rounded-xl text-sm font-medium flex items-center gap-2 hover:bg-rose-600 shadow-sm">
                <Plus className="w-4 h-4" /> เพิ่มวัตถุดิบ
              </button>
            </div>

            <div className="overflow-x-auto">
              <table className="w-full text-left border-collapse">
                <thead>
                  <tr className="border-b border-slate-200 bg-slate-50 text-slate-600 text-sm">
                    <th className="p-3 font-semibold">ชื่อวัตถุดิบ</th>
                    <th className="p-3 font-semibold">ปริมาณซื้อยกแพ็ค</th>
                    <th className="p-3 font-semibold">หน่วยที่ซื้อ</th>
                    <th className="p-3 font-semibold">ราคายกแพ็ค (บาท)</th>
                    <th className="p-3 font-semibold text-center">ลบ</th>
                  </tr>
                </thead>
                <tbody>
                  {materials.map((mat) => (
                    <tr key={mat.id} className="border-b border-slate-100 hover:bg-slate-50/50">
                      <td className="p-3">
                        <input 
                          type="text" value={mat.name} 
                          onChange={(e) => setMaterials(materials.map(m => m.id === mat.id ? {...m, name: e.target.value} : m))}
                          className="w-full border border-slate-200 rounded-lg px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-rose-500"
                        />
                      </td>
                      <td className="p-3">
                        <input 
                          type="number" value={mat.packSize} 
                          onChange={(e) => setMaterials(materials.map(m => m.id === mat.id ? {...m, packSize: e.target.value} : m))}
                          className="w-24 border border-slate-200 rounded-lg px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-rose-500"
                        />
                      </td>
                      <td className="p-3">
                        <select 
                          value={mat.unit}
                          onChange={(e) => setMaterials(materials.map(m => m.id === mat.id ? {...m, unit: e.target.value} : m))}
                          className="border border-slate-200 rounded-lg px-2 py-1 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-rose-500"
                        >
                          {Object.keys(UNITS).map(k => <option key={k} value={k}>{UNITS[k].name}</option>)}
                        </select>
                      </td>
                      <td className="p-3">
                        <input 
                          type="number" value={mat.pricePerUnit} 
                          onChange={(e) => setMaterials(materials.map(m => m.id === mat.id ? {...m, pricePerUnit: e.target.value} : m))}
                          className="w-28 border border-slate-200 rounded-lg px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-rose-500"
                        />
                      </td>
                      <td className="p-3 text-center">
                        <button 
                          onClick={() => setMaterials(materials.filter(m => m.id !== mat.id))}
                          className="text-slate-400 hover:text-red-500 p-1 rounded-md transition-colors"
                        >
                          <Trash2 className="w-4 h-4" />
                        </button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {activeTab === "products" && (
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
            {/* รายชื่อขนม */}
            <div className="lg:col-span-2 bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
              <h2 className="text-lg font-bold mb-4">เมนูเบเกอรี่ของคุณ</h2>
              <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {products.map((p, idx) => {
                  const info = costOf(p, materials);
                  return (
                    <div 
                      key={p.id} onClick={() => setSelectedProduct(p)}
                      className={`p-4 rounded-xl border transition-all cursor-pointer ${selectedProduct?.id === p.id ? "border-rose-500 bg-rose-50/30 ring-1 ring-rose-500" : "border-slate-200 bg-white hover:border-slate-300"}`}
                    >
                      <div className="flex justify-between items-start mb-2">
                        <span className="font-bold text-slate-800" style={{ color: accentFor(idx) }}>{p.name}</span>
                        <span className="text-xs font-semibold bg-slate-100 text-slate-600 px-2 py-0.5 rounded-full">Yield: {info.yieldCount} ชิ้น</span>
                      </div>
                      <div className="mt-4 pt-3 border-t border-slate-100 flex justify-between text-xs text-slate-500">
                        <div>ต้นทุน/ชิ้น: <span className="font-semibold text-slate-700">{baht(info.costPerPiece)} ฿</span></div>
                        <div>ราคาขาย: <span className="font-semibold text-rose-600">{baht(p.sellingPrice)} ฿</span></div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>

            {/* ส่วนตั้งค่า PromptPay ท้ายหน้า */}
            <div className="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm h-fit">
              <h3 className="font-bold mb-2 flex items-center gap-2 text-slate-800"><QrCode className="w-4 h-4 text-rose-500" /> ตั้งค่า PromptPay QR</h3>
              <input 
                type="text" placeholder="เบอร์โทรศัพท์ หรือ เลขบัตร ปชช." value={promptPayId} 
                onChange={(e) => setPromptPayId(e.target.value)}
                className="w-full text-sm border border-slate-200 rounded-xl px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-rose-500"
              />
              <p className="text-[11px] text-slate-400 mt-1">ใช้สำหรับการคำนวณสร้าง QR Code สแกนจ่ายหน้าร้านเมื่อพิมพ์บิล</p>
            </div>
          </div>
        )}
      </main>
    </div>
  );
}
