  useEffect(() => {
    async function init() {
      const storedMaterials = await loadKey("bakery_materials", []);
      const storedProducts = await loadKey("bakery_products", defaultProducts());
      const storedPp = await loadKey("bakery_pp_id", "");
      setMaterials(storedMaterials);
      setProducts(storedProducts);
      setPromptPayId(storedPp);
